<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             version="3.0"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="hibernate-postgresql">
        <description>Usa o provedor Hibernate com PostgreSQL</description>
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>modelo_negocio.Contato</class>
        <class>modelo_negocio.ContatoPessoal</class>
        <class>modelo_negocio.ContatoComercial</class>
        <class>modelo_negocio.Cidade</class>
        <shared-cache-mode>NONE</shared-cache-mode>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5434/agenda"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="ifpb"/>

            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.show_sql" value="false"/>
        </properties>
    </persistence-unit>

    <persistence-unit name="hibernate-mysql">
        <description>Usa o provedor Hibernate com MySQL</description>
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>modelo_negocio.Contato</class>
        <class>modelo_negocio.ContatoPessoal</class>
        <class>modelo_negocio.ContatoComercial</class>
        <class>modelo_negocio.Cidade</class>
        <shared-cache-mode>NONE</shared-cache-mode>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/agenda"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>

            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.show_sql" value="false"/>
        </properties>
    </persistence-unit>
</persistence>
